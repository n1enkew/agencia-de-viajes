   <property name="styleSheet">
    <string notr="true">/* ========================================================
   ESTILOS GENERALES (Fondo y Textos)
======================================================== */
QMainWindow, QWidget#centralwidget {
    background-color: #F4F7F9; /* Un gris azulado muy claro y limpio */
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
    color: #333333;
}

QLabel {
    font-size: 14px;
    font-weight: bold;
    color: black;
}

/* Título principal del Login */
QLabel#lbl_titulo_login {
    font-size: 24px;
    color: #0056b3;
    font-weight: bold;
}

/* Mensaje de error en rojo */
QLabel#lbl_mensaje {
    color: #E74C3C;
    font-weight: normal;
    font-size: 12px;
}

/* ========================================================
   QSTACKEDWIDGET (Contenedor principal)
======================================================== */
QStackedWidget {
    background-color: transparent;
    border: none;
}

/* ========================================================
   CAJAS DE TEXTO (QLineEdit - Login y Formularios)
======================================================== */
QLineEdit {
    background-color: #FFFFFF;
    border: 2px solid #DCE4EC;
    border-radius: 6px;
    padding: 8px 12px;
    font-size: 14px;
    color: #2C3E50;
}

/* Efecto al hacer clic en la caja de texto */
QLineEdit:focus {
    border: 2px solid #3498DB; /* Borde azul cuando escribes */
    background-color: #FDFEFE;
}

/* ========================================================
   BOTONES (QPushButton)
======================================================== */
QPushButton {
    background-color: #3498DB; /* Azul corporativo */
    color: white;
    border: none;
    border-radius: 6px;
    padding: 10px 15px;
    font-size: 14px;
    font-weight: bold;
}

/* Efecto al pasar el mouse */
QPushButton:hover {
    background-color: #2980B9;
}

/* Efecto al hacer clic */
QPushButton:pressed {
    background-color: #1F618D;
}

/* Botón secundario o de Cancelar/Eliminar (puedes asignarle una clase o nombre específico luego si quieres) */
QPushButton#btn_eliminar {
    background-color: #E74C3C;
}
QPushButton#btn_eliminar:hover {
    background-color: #C0392B;
}

/* ========================================================
   PESTAÑAS DEL DASHBOARD (QTabWidget)
======================================================== */
QTabWidget::pane {
    border: 1px solid #DCE4EC;
    background-color: #FFFFFF;
    border-radius: 6px;
    margin-top: -1px; /* Oculta la línea debajo de las pestañas */
}

QTabBar::tab {
    background-color: #EAECEE;
    color: #7F8C8D;
    border: 1px solid #DCE4EC;
    border-bottom-color: #DCE4EC; /* Igual que el panel */
    border-top-left-radius: 6px;
    border-top-right-radius: 6px;
    padding: 10px 20px;
    margin-right: 2px;
    font-size: 13px;
    font-weight: bold;
}

/* Efecto al pasar el mouse por las pestañas */
QTabBar::tab:hover {
    background-color: #D6DBDF;
}

/* Pestaña activa (La que estás viendo) */
QTabBar::tab:selected {
    background-color: #FFFFFF;
    color: #2C3E50;
    border-bottom-color: #FFFFFF; /* Se fusiona visualmente con el panel */
}

/* ========================================================
   TABLAS (QTableWidget - Para mostrar los destinos/reservas)
======================================================== */
QTableWidget {
    background-color: #FFFFFF;
    border: 1px solid #DCE4EC;
    border-radius: 6px;
    gridline-color: #ECF0F1;
    font-size: 13px;
    color: #34495E;
}

QHeaderView::section {
    background-color: #34495E;
    color: white;
    padding: 6px;
    border: 1px solid #2C3E50;
    font-weight: bold;
    font-size: 13px;
}

QTableWidget::item:selected {
    background-color: #3498DB;
    color: white;
}</string>
